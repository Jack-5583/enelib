// ene lib — data model
// Mirrors the state shapes found in the Claude Design prototypes
// (project/ene lib.dc.html, project/ene lib (Mobile).dc.html)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  PARENT
}

enum ExamPaperKind {
  FULL    // 풀 모의고사 (전과목)
  SUBJECT // 과목별 모의고사
}

enum VerificationPurpose {
  LOGIN
  SIGNUP
}

enum VerificationStatus {
  PENDING
  CHECKING
  VERIFIED
  EXPIRED
}

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  role      Role
  name      String
  schoolLabel String @default("고3")
  createdAt DateTime @default(now())

  notificationSettings NotificationSettings?

  // student-owned data
  books        Book[]
  materialTags MaterialTag[]
  examTypeOptions ExamTypeOption[]
  examPapers   ExamPaper[]
  examSeries   ExamSeries[]
  todos        Todo[]
  exams        Exam[]
  ddays        Dday[]
  questions    Question[]
  hohoonAccount   HohoonAccount?
  hohoonDrafts    HohoonDraft[]
  hohoonQuestions HohoonQuestion[]
  sdijAccount     SdijAccount?
  inclassQuestions InclassQuestion[]
  camSessions  CamSession[]
  timelineEntries TimelineEntry[]
  studentAuthCodes StudentAuthCode[]

  // Naver Login (used only for TA 질문하기 → Naver Cafe posting)
  naverAccessToken     String?
  naverRefreshToken    String?
  naverTokenExpiresAt  DateTime?
  naverNickname        String?

  // parent <-> student links
  parentLinks  ParentStudentLink[] @relation("ParentLinks")
  studentLinks ParentStudentLink[] @relation("StudentLinks")

  sessions Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

/// Long random code a student generates to hand to a parent so the parent
/// can link their account (separate from the OCTOMO SMS verification code).
model StudentAuthCode {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  code      String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  usedByParentId String?

  @@index([studentId])
}

model ParentStudentLink {
  id        String   @id @default(cuid())
  parentId  String
  parent    User     @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  studentId String
  student   User     @relation("StudentLinks", fields: [studentId], references: [id], onDelete: Cascade)
  linkedAt  DateTime @default(now())

  @@unique([parentId, studentId])
  @@index([studentId])
}

/// OCTOMO phone verification attempt — used for both login and signup.
model VerificationRequest {
  id            String   @id @default(cuid())
  phone         String
  purpose       VerificationPurpose
  // Long random alphanumeric string embedded in the SMS body OCTOMO matches on.
  verifyCode    String   @unique
  status        VerificationStatus @default(PENDING)
  // Staged signup fields, consumed once verification succeeds.
  pendingRole       Role?
  pendingName       String?
  pendingStudentCode String?
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  verifiedAt    DateTime?

  @@index([phone])
  @@index([verifyCode])
}

model NotificationSettings {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  todoEnabled Boolean @default(true)
  examEnabled Boolean @default(true)
  camEnabled  Boolean @default(false)
}

model Book {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  subject   String
  title     String
  publisher String
  tags      String[]
  createdAt DateTime @default(now())

  todos Todo[]

  @@index([ownerId])
}

/// A user-managed filter tag shown above the materials (교재) list —
/// fully customizable instead of a fixed list.
model MaterialTag {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([ownerId, name])
  @@index([ownerId])
}

/// A user-managed exam-paper "종류" option (모평/학평/... by default, but
/// fully customizable) offered when registering an exam paper.
model ExamTypeOption {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([ownerId, name])
  @@index([ownerId])
}

/// A user-created countdown shown in Settings (in addition to the built-in
/// CSAT D-day).
model Dday {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  label      String
  targetDate DateTime @db.Date
  createdAt  DateTime @default(now())

  @@index([ownerId])
}

/// A named, ongoing set of subject-specific mock exams a student takes
/// repeatedly (e.g. "시대인재 모의고사"), registered one round at a time.
model ExamSeries {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  subject   String
  name      String
  createdAt DateTime @default(now())

  papers ExamPaper[]

  @@unique([ownerId, subject, name])
  @@index([ownerId, subject])
}

model ExamPaper {
  id        String        @id @default(cuid())
  ownerId   String
  owner     User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  kind      ExamPaperKind
  // SUBJECT kind only:
  subject   String?
  seriesId  String?
  series    ExamSeries?   @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  round     Int?
  maxScore  Int?
  // shared:
  title     String
  type      String
  examDate  String
  createdAt DateTime      @default(now())

  // FULL kind only:
  subjects ExamPaperSubject[]
  exams    Exam[]
  todos    Todo[]

  @@index([ownerId])
}

/// Per-subject max score for a FULL (전과목) exam paper.
model ExamPaperSubject {
  id          String    @id @default(cuid())
  examPaperId String
  examPaper   ExamPaper @relation(fields: [examPaperId], references: [id], onDelete: Cascade)
  subject     String
  maxScore    Int

  @@unique([examPaperId, subject])
}

model Todo {
  id         String    @id @default(cuid())
  ownerId    String
  owner      User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  subject    String
  title      String
  date       DateTime  @db.Date
  done       Boolean   @default(false)
  bookId     String?
  book       Book?     @relation(fields: [bookId], references: [id], onDelete: SetNull)
  examPaperId String?
  examPaper   ExamPaper? @relation(fields: [examPaperId], references: [id], onDelete: SetNull)
  materialLabel String?
  memo       String?
  photoUrl   String?
  createdAt  DateTime  @default(now())

  @@index([ownerId, date])
}

model Exam {
  id          String    @id @default(cuid())
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  examPaperId String
  examPaper   ExamPaper @relation(fields: [examPaperId], references: [id], onDelete: Cascade)
  subject     String
  raw         Int
  grade       Int
  pct         Int?
  std         Int?
  wrong       String[]
  memo        String?
  createdAt   DateTime  @default(now())

  @@unique([examPaperId, subject])
  @@index([ownerId, subject])
}

model CamSession {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  intervalMinutes Int    @default(10)
  totalSeconds Int       @default(0)

  timelineEntries TimelineEntry[]

  @@index([ownerId])
}

model TimelineEntry {
  id            String   @id @default(cuid())
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  camSessionId  String?
  camSession    CamSession? @relation(fields: [camSessionId], references: [id], onDelete: SetNull)
  capturedAt    DateTime @default(now())
  endedAt       DateTime?
  subject       String?
  todoTitle     String?
  durationLabel String?
  photoUrls     String[] @default([])
  createdAt     DateTime @default(now())

  memo TimelineMemo?

  @@index([ownerId, capturedAt])
}

model TimelineMemo {
  id              String   @id @default(cuid())
  timelineEntryId String   @unique
  timelineEntry   TimelineEntry @relation(fields: [timelineEntryId], references: [id], onDelete: Cascade)
  dataUrl         String   @db.Text
  penColor        String   @default("#e0362f")
  updatedAt       DateTime @updatedAt
}

/// A "TA 질문하기" question, mirrored out to a linked Naver Cafe as a real post.
model Question {
  id             String   @id @default(cuid())
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  labId          String
  boardId        String
  subject        String
  title          String
  content        String   @db.Text
  photoUrls      String[] @default([])
  postStatus     String   @default("pending") // pending | posted | failed
  postError      String?
  cafeClubUrl    String?
  cafeArticleId  String?
  cafeArticleUrl String?
  commentCount   Int      @default(0)
  hasUnseenReply Boolean  @default(false)
  done           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([ownerId])
}

/// A student's saved hohoonmath.com login, used to post study questions to that
/// board on their behalf. Credentials are stored AES-256-GCM encrypted.
model HohoonAccount {
  id          String   @id @default(cuid())
  ownerId     String   @unique
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  userIdEnc   String    // encrypted hohoonmath login id
  userPassEnc String    // encrypted hohoonmath password
  writerName  String?   // cached board nickname (prefilled by the write form)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// A short-lived compose session. hohoonmath's captcha answer is bound to the
/// PHP session that fetched the image, so we must hold that live session cookie
/// server-side between "show captcha", "upload images", and "submit".
model HohoonDraft {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  phpsessid  String    // live hohoonmath session cookie (name=value)
  imgcode    String    // temp image folder id shared by this post's uploads
  writerName String
  imagePaths String[] @default([])
  createdAt  DateTime @default(now())

  @@index([ownerId])
}

/// A study question a student posted to hohoonmath, mirrored locally so we can
/// show it in-app and (later) surface replies.
model HohoonQuestion {
  id             String   @id @default(cuid())
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  subject        String
  body           String   @db.Text
  imagePaths     String[] @default([])
  articleId      String?
  articleUrl     String?
  answerText     String?  @db.Text
  answeredAt     DateTime?
  commentCount   Int      @default(0)
  hasUnseenReply Boolean  @default(false)
  done           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([ownerId])
}

/// The student's authenticated SDIJ (시대인재) session, captured once so we can
/// replay the 부엉이 포스트 grade report server-side without re-auth. Auth is ASP
/// session cookies + the studeepForm hidden fields (authIdx / UserDate), both
/// stored encrypted and refreshed from each successful response.
model SdijAccount {
  id        String   @id @default(cuid())
  ownerId   String   @unique
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  cookieEnc String   @db.Text
  bodyEnc   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A study question posted to 박종민수학연구소 (gomathtop.inclass.co.kr),
/// mirrored locally. Posting goes through one shared inclass session, like the
/// 호형훈제 integration.
model InclassQuestion {
  id             String   @id @default(cuid())
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  subject        String
  body           String   @db.Text
  imagePaths     String[] @default([])
  articleId      String?
  articleUrl     String?
  answerText     String?  @db.Text
  answeredAt     DateTime?
  commentCount   Int      @default(0)
  hasUnseenReply Boolean  @default(false)
  done           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([ownerId])
}
